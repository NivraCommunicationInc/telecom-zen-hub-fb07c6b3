# ==============================================
# Nivra Telecom – Environment Variables
# Copy this file to .env and fill in real values
# ==============================================

# ── Backend (Supabase / Lovable Cloud) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_ref_here

# ── App URL (used for absolute links, OG tags) ──
VITE_APP_URL=https://nivra-telecom.ca

# ── Core Admin Base Path (default: /core) ──
# VITE_CORE_BASE_PATH=/core

# ── Stripe (publishable keys only – secret keys stay in Edge Functions) ──
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_key_here
# VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_your_key_here

# ── PayPal (client ID – secret stays in Edge Functions) ──
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ── Cloudflare Turnstile (anti-bot CAPTCHA) ──
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# ── Google reCAPTCHA v3 (alternative anti-bot) ──
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ── Mapbox (public token) ──
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── KYC Debug (dev only – never enable in production) ──
# VITE_KYC_DEBUG=false

# ── E2E Testing (dev only) ──
# VITE_E2E_MODE=false
# VITE_E2E_TEST_EMAIL=test@example.com

# ── Privacy (Loi 25) ──
VITE_PRIVACY_EMAIL=confidentialite@nivra-telecom.ca

# ── Sentry (error monitoring) ──
# 1. Sign up at https://sentry.io, create a React project
# 2. Copy the DSN below. Leave blank to disable (no-op).
# VITE_SENTRY_DSN=https://abc123@o12345.ingest.sentry.io/678910
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=v1.0.0

# ==============================================
# Edge Function Secrets (set via Lovable Cloud)
# These are NOT prefixed with VITE_ and never
# exposed to the frontend bundle.
# ==============================================
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# RESEND_API_KEY=your_resend_api_key
# STRIPE_SECRET_KEY=sk_test_your_key
# OPENPHONE_API_KEY=your_openphone_key
# NIVRA_WEBHOOK_SECRET=your_webhook_secret
# ENVIRONMENT=production

# Sentry for edge functions (Deno) — same DSN as VITE_SENTRY_DSN works
# SENTRY_DSN=https://abc123@o12345.ingest.sentry.io/678910
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=v1.0.0

# Shared secret for cron-triggered agent functions (agent-crm-email-blast etc.)
# Cron uses SUPABASE_SERVICE_ROLE_KEY by default; this lets you grant access
# to additional callers without sharing the service role key.
# AGENT_SECRET=your_random_long_secret_here
