# ==============================================
# Nivra Telecom – Environment Variables
# Copy this file to .env and fill in real values
# ==============================================

# ── Backend (Supabase / Lovable Cloud) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_ref_here

# ── Stripe (publishable keys only – secret keys stay in Edge Functions) ──
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_key_here
# VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_your_key_here

# ── PayPal (client ID – secret stays in Edge Functions) ──
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ── Cloudflare Turnstile (anti-bot CAPTCHA) ──
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# ── Google reCAPTCHA v3 (alternative anti-bot) ──
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ── Mapbox (public token) ──
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── Privacy (Loi 25) ──
VITE_PRIVACY_EMAIL=confidentialite@nivra-telecom.ca
